{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": "",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "^/api/db/status/?$",
      "dest": "/api/db/index",
      "transforms": [
        {
          "type": "request.headers",
          "op": "set",
          "target": { "key": "x-oi-db-route" },
          "args": "status"
        }
      ]
    },
    {
      "src": "^/api/db/merchant/?$",
      "dest": "/api/db/index",
      "transforms": [
        {
          "type": "request.headers",
          "op": "set",
          "target": { "key": "x-oi-db-route" },
          "args": "merchant"
        }
      ]
    },
    {
      "src": "^/api/db/search/?$",
      "dest": "/api/db/index",
      "transforms": [
        {
          "type": "request.headers",
          "op": "set",
          "target": { "key": "x-oi-db-route" },
          "args": "search"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.py": {
      "includeFiles": "protected_data/**",
      "excludeFiles": "{scripts/**,.git/**}",
      "maxDuration": 60
    }
  }
}
